{
  "name": "@form8ion/overridable-prompts",
  "description": "Inquirer prompts that can be overriden with provided answers",
  "license": "MIT",
  "version": "0.0.0-semantically-released",
  "type": "commonjs",
  "author": "Matt Travi <npm@travi.org> (https://matt.travi.org/)",
  "repository": "form8ion/overridable-prompts",
  "bugs": "https://github.com/form8ion/overridable-prompts/issues",
  "homepage": "https://www.npmjs.com/package/@form8ion/overridable-prompts",
  "main": "lib/index.cjs.js",
  "module": "lib/index.es.js",
  "sideEffects": false,
  "scripts": {
    "test": "npm-run-all --print-label --parallel lint:* --parallel test:*",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "run-s 'lint:js -- --fix'",
    "lint:lockfile": "lockfile-lint",
    "prelint:md": "npm run build",
    "lint:md": "remark . --frail",
    "lint:peer": "npm ls >/dev/null",
    "lint:sensitive": "ban",
    "test:unit": "cross-env NODE_ENV=test c8 run-s test:unit:base",
    "test:unit:base": "DEBUG=any mocha 'src/**/*-test.js'",
    "prebuild": "run-s clean",
    "build": "npm-run-all --print-label --parallel build:*",
    "build:js": "rollup --config",
    "clean": "rimraf ./lib",
    "pregenerate:md": "npm run build",
    "generate:md": "remark . --output",
    "prepack": "run-s build",
    "prepare": "husky",
    "watch": "run-s 'build:js -- --watch'"
  },
  "files": [
    "lib/"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@11.15.0+sha512.fa4d2d93b9519e93143e70bb913b94ff2ad5fe69c5a0f84943be557cbb59e9fc1bcce55768fb1313f225f4f9f50c78b8f366f2332aa41effd7b10efa98d8d72f",
  "dependencies": {
    "inquirer": "^8.0.0"
  },
  "devDependencies": {
    "@babel/register": "7.29.3",
    "@form8ion/babel-preset": "1.6.154",
    "@form8ion/commitlint-config": "2.0.15",
    "@form8ion/eslint-config": "8.0.0-beta.1",
    "@form8ion/eslint-config-mocha": "3.0.6",
    "@form8ion/remark-lint-preset": "6.0.7",
    "@travi/any": "3.3.0",
    "ban-sensitive-files": "1.10.11",
    "c8": "10.1.3",
    "chai": "4.5.0",
    "cross-env": "7.0.3",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "lockfile-lint": "4.14.1",
    "mocha": "11.1.0",
    "npm-run-all2": "7.0.2",
    "remark-cli": "12.0.1",
    "remark-toc": "9.0.0",
    "remark-usage": "11.0.1",
    "rimraf": "6.0.1",
    "rollup": "4.59.0",
    "rollup-plugin-auto-external": "2.0.0",
    "sinon": "19.0.5"
  }
}
